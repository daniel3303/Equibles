# Equibles Configuration
# Copy this file to .env and fill in the required settings.

# --- SEC EDGAR (required) ---
# SEC requires a contact email in the User-Agent header for programmatic access.
# See: https://www.sec.gov/os/accessing-edgar-data
SEC_CONTACT_EMAIL=your-email@example.com

# --- Authentication (optional — leave empty for open access) ---
# AUTH_USERNAME=admin
# AUTH_PASSWORD=changeme

# --- MCP API Key (optional — leave empty for open access) ---
# MCP_API_KEY=your-api-key

# --- Logging ---
# Options: Verbose, Debug, Information, Warning, Error, Fatal
# MINIMUM_LOG_LEVEL=Warning

# --- FINRA Short Data (free API key from developer.finra.org) ---
# Finra__ClientId=
# Finra__ClientSecret=

# --- Ticker Filtering (optional — sync all tickers when not set) ---
# DocumentScraperOptions__TickersToSync__0=AAPL
# DocumentScraperOptions__TickersToSync__1=MSFT
# HoldingsScraperOptions__TickersToSync__0=AAPL
# HoldingsScraperOptions__TickersToSync__1=MSFT
# CongressScraperOptions__TickersToSync__0=AAPL
# CongressScraperOptions__TickersToSync__1=MSFT
# FinraScraperOptions__TickersToSync__0=AAPL
# FinraScraperOptions__TickersToSync__1=MSFT
