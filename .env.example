# Equibles Configuration
# Copy this file to .env and fill in the required settings.

# --- SEC EDGAR (required) ---
# SEC requires a contact email in the User-Agent header for programmatic access.
# See: https://www.sec.gov/os/accessing-edgar-data
SEC_CONTACT_EMAIL=myname@example.com

# --- Authentication (optional — leave empty for open access) ---
# AUTH_USERNAME=admin
# AUTH_PASSWORD=changeme

# --- MCP API Key (optional — leave empty for open access) ---
MCP_API_KEY=my-secret-key

# --- Logging ---
# Options: Verbose, Debug, Information, Warning, Error, Fatal
MINIMUM_LOG_LEVEL=Warning

# --- Update notifications (optional — defaults to true when unset) ---
# When true, the Web portal periodically checks GitHub Releases and shows a
# banner if a newer version is available. Set to false to disable the check.
# CHECK_FOR_UPDATES=true

# --- FINRA Short Data (free API key from gateway.finra.org/app/api-console) ---
# Finra__ClientId=my-finra-client-id
# Finra__ClientSecret=my-finra-client-secret

# --- FRED Economic Data (free API key from fred.stlouisfed.org/docs/api/api_key.html) ---
# Fred__ApiKey=my-fred-api-key

# --- Minimum Sync Date (optional — defaults to 2020-01-01) ---
# How far back to sync data. Can go as far back as 2000-01-01, or set a recent date for faster initial sync.
# Worker__MinSyncDate=2024-01-01

# --- Ticker Filtering (optional — sync all tickers when not set) ---
# Worker__TickersToSync__0=AAPL
# Worker__TickersToSync__1=MSFT

# --- Vector Embeddings (optional — disabled by default) ---
# Requires an Ollama or OpenAI-compatible embedding endpoint.
# Use "docker compose --profile embedding up" to start the bundled Ollama server.
# Embedding__Enabled=true
# Embedding__BaseUrl=http://localhost:11434
# Embedding__ModelName=bge-m3
# Embedding__BatchSize=10
