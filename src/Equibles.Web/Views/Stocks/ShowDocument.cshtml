@using Equibles.Core.Extensions
@using Equibles.Web.Extensions
@model Equibles.Web.ViewModels.Stocks.DocumentViewModel

@{
    var doc = Model.Document;
    ViewData["Description"] = $"{doc.DocumentType.DisplayName} filing for {Model.Ticker}. View the full SEC document content.";
}

<div class="max-w-6xl mx-auto px-6 py-8">
    <!-- Breadcrumb -->
    <div class="flex items-center justify-between mb-2">
        <div class="breadcrumbs text-sm text-base-content/60">
            <ul>
                <li><a asp-controller="Stocks" asp-action="Index">Stocks</a></li>
                <li>
                    <a asp-controller="Stocks" asp-action="Show" asp-route-ticker="@Model.Ticker">
                        @Model.Ticker
                    </a>
                </li>
                <li>
                    <span class="font-semibold text-base-content">@doc.DocumentType.DisplayName</span>
                </li>
            </ul>
        </div>
    </div>

    <!-- Document Header -->
    <div class="card bg-base-100 shadow-sm mb-8">
        <div class="card-body p-4 lg:p-6">
            <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                    <h1 class="text-2xl font-bold mb-2">@doc.DocumentType.DisplayName</h1>
                    <p class="text-base-content/60 mb-3">@doc.CommonStock.Name (@doc.CommonStock.Ticker)</p>
                    <div class="flex gap-2 flex-wrap">
                        <span class="badge badge-primary">@doc.DocumentType.DisplayName</span>
                        <span class="badge badge-info">@doc.ReportingDate.ToString("yyyy-MM-dd")</span>
                        <span class="badge badge-neutral">For: @doc.ReportingForDate.ToString("yyyy-MM-dd")</span>
                    </div>
                </div>
                <div class="text-end">
                    @if (!string.IsNullOrEmpty(doc.SourceUrl)) {
                        <a href="@doc.SourceUrl" target="_blank" rel="noopener" class="btn btn-outline btn-primary btn-sm mb-2">
                            <icon name="arrow-top-right-on-square" size="4" /> View Original
                        </a>
                    }
                    <div>
                        <small class="text-base-content/60 block">Added on</small>
                        <strong>@doc.CreationTime.ToString("MMMM dd, yyyy")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Document Content -->
    <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-4 lg:p-6">
            @if (!string.IsNullOrEmpty(Model.Content)) {
                <div class="prose max-w-none">
                    @Html.MarkdownToHtml(Model.Content)
                </div>
            } else {
                <div class="text-center py-8">
                    <div class="mb-3 text-base-content/30">
                        <icon name="document" size="12" />
                    </div>
                    <h3 class="text-base-content/60 mb-2">No content available</h3>
                    <p class="text-base-content/50 text-sm">The document content could not be loaded or is empty.</p>
                </div>
            }
        </div>
    </div>
</div>
