@model Equibles.Web.ViewModels.Stocks.FtdTabViewModel

<partial name="_TabIntro" model="@("Fails to deliver — shares from a trade that were not delivered to the buyer by the settlement date — published by the SEC twice a month. Persistent fails can reflect settlement problems or naked short selling.")" />

@if (Model.FailsToDeliver.Count == 0) {
    <partial name="_EmptyStateCard" model='(IconName: "exclamation-triangle", Heading: "No Fails to Deliver Data", Message: "No fails-to-deliver data is available for this stock yet.")' />
} else {
    <!-- Chart -->
    <partial name="_ChartCard" model='("Fails to Deliver History", "ftd-chart", "Fails-to-deliver history", "h-[200px]", "mb-4")' />

    <!-- Table -->
    <table-card>
                <thead>
                    <tr>
                        <th scope="col">Settlement Date</th>
                        <th scope="col" class="text-right">Quantity</th>
                        <th scope="col" class="text-right">Price</th>
                        <th scope="col" class="text-right">Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ftd in Model.FailsToDeliver.OrderByDescending(f => f.SettlementDate)) {
                        <tr>
                            <td>@ftd.SettlementDate.ToString("yyyy-MM-dd")</td>
                            <td class="text-right font-mono"><compactable-number value="@ftd.Quantity" /></td>
                            <td class="text-right font-mono">$@ftd.Price.ToString("F2")</td>
                            <td class="text-right font-mono"><compactable-number value="@(ftd.Quantity * ftd.Price)" prefix="$" /></td>
                        </tr>
                    }
                </tbody>
            </table-card>

    <partial name="_ChartJs" />
    <script>
    // Render fails-to-deliver bar chart (waits for Chart.js bundle)
    document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('ftd-chart');
        if (!ctx || typeof Chart === 'undefined') return;

        const labels = @Html.Json(Model.FailsToDeliver.Select(f => f.SettlementDate.ToString("yyyy-MM-dd")).ToList());
        const quantities = @Html.Json(Model.FailsToDeliver.Select(f => f.Quantity).ToList());

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'FTD Quantity',
                    data: quantities,
                    backgroundColor: 'oklch(80% 0.18 85 / 0.7)',
                    borderRadius: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: { ticks: { maxTicksLimit: 12, font: { size: 10 } } },
                    y: { ticks: { callback: v => v >= 1e6 ? (v/1e6).toFixed(1)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v } }
                },
                plugins: { legend: { display: false } }
            }
        });
    });
    </script>
}
