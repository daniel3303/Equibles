@model Equibles.Web.ViewModels.EconomicData.EconomyIndexViewModel

@{
    ViewData["Title"] = "Economic Data";
    ViewData["Description"] = "Browse FRED economic indicators — interest rates, inflation, employment, GDP, and more.";
}

<div class="max-w-6xl mx-auto px-6 py-12">
    <div class="mb-8">
        <h1 class="text-3xl font-bold mb-2">Economic Data</h1>
        <p class="text-base-content/60">
            @Model.Categories.Sum(c => c.Series.Count) indicators from
            <a href="https://fred.stlouisfed.org" target="_blank" rel="noopener" class="link link-primary">FRED</a>
            across @Model.Categories.Count categories.
            Click any indicator to explore charts, statistics, and historical data.
        </p>
    </div>

    <div class="space-y-6">
        @foreach (var category in Model.Categories) {
            <div class="card bg-base-100 shadow-sm">
                <div class="card-body p-4 lg:p-6">
                    <h2 class="card-title text-lg mb-3">@category.DisplayName</h2>
                    <div class="overflow-x-auto">
                        <table class="table table-zebra table-sm">
                            <thead>
                                <tr>
                                    <th>Series</th>
                                    <th>Name</th>
                                    <th class="hidden md:table-cell">Frequency</th>
                                    <th class="text-right">Latest Value</th>
                                    <th class="text-right hidden sm:table-cell">Date</th>
                                    <th class="w-8"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var series in category.Series) {
                                    <tr class="hover cursor-pointer economy-row"
                                        data-href="@Url.Action("Show", "EconomicData", new { seriesId = series.SeriesId })">
                                        <td>
                                            <a asp-action="Show" asp-route-seriesId="@series.SeriesId"
                                               class="font-mono text-sm link link-primary">@series.SeriesId</a>
                                        </td>
                                        <td class="max-w-xs truncate">@series.Title</td>
                                        <td class="hidden md:table-cell text-base-content/60 text-sm">@series.Frequency</td>
                                        <td class="text-right font-semibold tabular-nums">
                                            @if (series.LatestValue.HasValue) {
                                                @series.LatestValue.Value.ToString("N2")
                                            } else {
                                                <span class="text-base-content/30">&mdash;</span>
                                            }
                                        </td>
                                        <td class="text-right text-sm text-base-content/60 hidden sm:table-cell">
                                            @if (series.LatestDate.HasValue) {
                                                @series.LatestDate.Value.ToString("yyyy-MM-dd")
                                            }
                                        </td>
                                        <td class="text-base-content/30">
                                            <icon name="chevron-right" size="4" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
    // Make table rows clickable to navigate to the series detail page
    document.querySelectorAll('.economy-row').forEach(function(row) {
        row.addEventListener('click', function(e) {
            if (e.target.closest('a')) return; // let native link clicks through
            window.location.href = this.dataset.href;
        });
    });
    </script>
}
