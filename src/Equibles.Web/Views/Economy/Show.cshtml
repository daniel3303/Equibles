@model Equibles.Web.ViewModels.Economy.EconomySeriesViewModel

@{
    // Chronological order for chart
    var chronological = Model.Observations
        .Where(o => o.Value.HasValue)
        .OrderBy(o => o.Date)
        .ToList();
}

<div class="max-w-6xl mx-auto px-6 py-8">
    <!-- Breadcrumb -->
    <div class="breadcrumbs text-sm text-base-content/60 mb-2">
        <ul>
            <li><a asp-controller="Economy" asp-action="Index">Economic Data</a></li>
            <li>
                <span class="font-semibold text-base-content">@Model.SeriesId</span>
            </li>
        </ul>
    </div>

    <!-- Series Header -->
    <div class="card bg-base-100 shadow-sm mb-6">
        <div class="card-body p-4 lg:p-6">
            <div class="flex flex-col lg:flex-row lg:justify-between gap-4">
                <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-3 mb-1">
                        <h1 class="text-2xl font-bold">@Model.SeriesId</h1>
                        <span class="badge badge-ghost">@Model.CategoryDisplayName</span>
                    </div>
                    <p class="text-base text-base-content/70">@Model.Title</p>
                </div>

                <div class="grid grid-cols-2 gap-x-6 gap-y-3 lg:gap-x-8 lg:border-l lg:border-base-200 lg:pl-6 border-t lg:border-t-0 pt-4 lg:pt-0 shrink-0">
                    <div>
                        <div class="text-xs text-base-content/50 uppercase tracking-wider">Units</div>
                        <div class="text-sm">@Model.Units</div>
                    </div>
                    <div>
                        <div class="text-xs text-base-content/50 uppercase tracking-wider">Frequency</div>
                        <div class="text-sm">@Model.Frequency</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.SeasonalAdjustment)) {
                        <div>
                            <div class="text-xs text-base-content/50 uppercase tracking-wider">Seasonal Adj.</div>
                            <div class="text-sm">@Model.SeasonalAdjustment</div>
                        </div>
                    }
                    <div>
                        <div class="text-xs text-base-content/50 uppercase tracking-wider">FRED</div>
                        <a href="https://fred.stlouisfed.org/series/@Model.SeriesId" target="_blank" rel="noopener"
                           class="text-sm link link-primary">View on FRED</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (chronological.Count > 0) {
        <!-- Statistics Cards (computed over displayed observations) -->
        <div class="flex items-baseline gap-2 mb-2">
            <h2 class="font-semibold text-sm">Statistics</h2>
            <span class="text-xs text-base-content/50">last @Model.Observations.Count observations</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-6">
            @if (Model.LatestValue.HasValue) {
                var change = Model.PreviousValue.HasValue ? Model.LatestValue.Value - Model.PreviousValue.Value : (decimal?)null;
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body p-3">
                        <div class="text-xs text-base-content/50 uppercase tracking-wider">Latest</div>
                        <div class="text-lg font-bold tabular-nums">@Model.LatestValue.Value.ToString("N2")</div>
                        @if (change.HasValue) {
                            <div class="text-xs tabular-nums @(change.Value > 0 ? "text-success" : change.Value < 0 ? "text-error" : "text-base-content/50")">
                                @(change.Value > 0 ? "+" : "")@change.Value.ToString("N2")
                            </div>
                        }
                    </div>
                </div>
            }
            @if (Model.Mean.HasValue) {
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body p-3">
                        <div class="text-xs text-base-content/50 uppercase tracking-wider">Mean</div>
                        <div class="text-lg font-bold tabular-nums">@Model.Mean.Value.ToString("N2")</div>
                    </div>
                </div>
            }
            @if (Model.Median.HasValue) {
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body p-3">
                        <div class="text-xs text-base-content/50 uppercase tracking-wider">Median</div>
                        <div class="text-lg font-bold tabular-nums">@Model.Median.Value.ToString("N2")</div>
                    </div>
                </div>
            }
            @if (Model.StdDev.HasValue) {
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body p-3">
                        <div class="text-xs text-base-content/50 uppercase tracking-wider">Std Dev</div>
                        <div class="text-lg font-bold tabular-nums">@Model.StdDev.Value.ToString("N2")</div>
                    </div>
                </div>
            }
            @if (Model.Min.HasValue) {
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body p-3">
                        <div class="text-xs text-base-content/50 uppercase tracking-wider">Min</div>
                        <div class="text-lg font-bold tabular-nums">@Model.Min.Value.ToString("N2")</div>
                    </div>
                </div>
            }
            @if (Model.Max.HasValue) {
                <div class="card bg-base-100 shadow-sm">
                    <div class="card-body p-3">
                        <div class="text-xs text-base-content/50 uppercase tracking-wider">Max</div>
                        <div class="text-lg font-bold tabular-nums">@Model.Max.Value.ToString("N2")</div>
                    </div>
                </div>
            }
        </div>

        <!-- Chart -->
        <div class="card bg-base-100 shadow-sm mb-6">
            <div class="card-body p-4 lg:p-6">
                <h2 class="font-semibold text-sm mb-3">@Model.Title (@Model.Units)</h2>
                <div class="h-[320px]">
                    <canvas id="economy-chart"></canvas>
                </div>
            </div>
        </div>
    }

    <!-- Observations Table -->
    <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-4 lg:p-6">
            <h2 class="card-title text-lg mb-3">
                Observations
                <span class="text-sm font-normal text-base-content/50">(@Model.Observations.Count most recent)</span>
            </h2>

            @if (Model.Observations.Count == 0) {
                <div class="text-center py-8 text-base-content/50">
                    <p class="text-sm">No observations yet</p>
                </div>
            } else {
                <div class="overflow-x-auto max-h-[400px] overflow-y-auto">
                    <table class="table table-zebra table-sm">
                        <thead class="sticky top-0 bg-base-100 z-10">
                            <tr>
                                <th>Date</th>
                                <th class="text-right">Value</th>
                                <th class="text-right hidden sm:table-cell">Change</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Observations.Count; i++) {
                                var obs = Model.Observations[i];
                                var prev = i + 1 < Model.Observations.Count ? Model.Observations[i + 1] : null;
                                var change = obs.Value.HasValue && prev?.Value != null ? obs.Value.Value - prev.Value.Value : (decimal?)null;
                                <tr>
                                    <td class="font-mono text-sm">@obs.Date.ToString("yyyy-MM-dd")</td>
                                    <td class="text-right font-semibold tabular-nums">
                                        @if (obs.Value.HasValue) {
                                            @obs.Value.Value.ToString("N2")
                                        } else {
                                            <span class="text-base-content/30">&mdash;</span>
                                        }
                                    </td>
                                    <td class="text-right text-sm tabular-nums hidden sm:table-cell @(change > 0 ? "text-success" : change < 0 ? "text-error" : "text-base-content/50")">
                                        @if (change.HasValue) {
                                            @(change.Value > 0 ? "+" : "")@change.Value.ToString("N2")
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@if (chronological.Count > 0) {
    @section Scripts {
        <script>
        // Render economy indicator line chart with 20/50-period SMA overlays
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('economy-chart');
            if (!ctx || typeof Chart === 'undefined') return;

            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chronological.Select(o => o.Date.ToString("yyyy-MM-dd")).ToList()));
            const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chronological.Select(o => o.Value).ToList()));
            const sma20 = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Sma20));
            const sma50 = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Sma50));

            const seriesLabel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SeriesId));
            const datasets = [{
                label: seriesLabel,
                data: values,
                borderColor: 'oklch(55% 0.15 250)',
                backgroundColor: 'oklch(55% 0.15 250 / 0.08)',
                fill: true,
                tension: 0.3,
                pointRadius: 0,
                pointHitRadius: 6,
                borderWidth: 2
            }];

            // Only show SMA lines if there's enough data
            const hasSma20 = sma20.some(v => v !== null);
            const hasSma50 = sma50.some(v => v !== null);

            if (hasSma20) {
                datasets.push({
                    label: 'SMA 20',
                    data: sma20,
                    borderColor: 'oklch(65% 0.2 145)',
                    borderWidth: 1.5,
                    borderDash: [4, 2],
                    pointRadius: 0,
                    fill: false,
                    tension: 0.3
                });
            }

            if (hasSma50) {
                datasets.push({
                    label: 'SMA 50',
                    data: sma50,
                    borderColor: 'oklch(65% 0.15 30)',
                    borderWidth: 1.5,
                    borderDash: [6, 3],
                    pointRadius: 0,
                    fill: false,
                    tension: 0.3
                });
            }

            new Chart(ctx, {
                type: 'line',
                data: { labels, datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false
                    },
                    scales: {
                        x: {
                            ticks: {
                                maxTicksLimit: 12,
                                font: { size: 10 }
                            }
                        },
                        y: {
                            ticks: {
                                callback: function(v) {
                                    if (Math.abs(v) >= 1e12) return (v / 1e12).toFixed(1) + 'T';
                                    if (Math.abs(v) >= 1e9) return (v / 1e9).toFixed(1) + 'B';
                                    if (Math.abs(v) >= 1e6) return (v / 1e6).toFixed(1) + 'M';
                                    if (Math.abs(v) >= 1e3) return (v / 1e3).toFixed(1) + 'K';
                                    return v;
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: { boxWidth: 12, font: { size: 11 } }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(ctx) {
                                    if (ctx.raw === null) return null;
                                    return ctx.dataset.label + ': ' + Number(ctx.raw).toLocaleString(undefined, {
                                        minimumFractionDigits: 2,
                                        maximumFractionDigits: 2
                                    });
                                }
                            }
                        }
                    }
                }
            });
        });
        </script>
    }
}
