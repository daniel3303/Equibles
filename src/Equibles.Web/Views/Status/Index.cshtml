@using Equibles.Errors.Data.Models
@model Equibles.Web.Models.SystemStatusViewModel

@{
    ViewData["Title"] = "Status";
    var search = ViewData["Search"] as string;
    var sourceFilter = ViewData["SourceFilter"] as string;
    var activeWorkers = Model.Workers.Count(w => w.Active);
    var totalWorkers = Model.Workers.Count;
}

<div class="max-w-6xl mx-auto px-6 py-8 space-y-8">

    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold">System Status</h1>
        <!-- Auto-refresh controls -->
        <div class="flex items-center gap-2">
            <span class="loading loading-ring loading-xs hidden" data-status-spinner></span>
            <span class="text-sm text-base-content/50" data-status-countdown></span>
            <div class="join">
                <button class="btn btn-xs join-item" data-status-interval="1">1s</button>
                <button class="btn btn-xs join-item btn-active" data-status-interval="5">5s</button>
                <button class="btn btn-xs join-item" data-status-interval="30">30s</button>
            </div>
            <input type="checkbox" class="toggle toggle-sm toggle-success" checked data-status-toggle title="Auto-refresh" />
        </div>
    </div>

    <!-- Security Warning -->
    @if (!Model.McpApiKeyConfigured) {
        <div class="alert alert-warning">
            <icon name="exclamation-triangle" size="5" />
            <div>
                <p class="font-semibold text-sm">MCP server is open to everyone</p>
                <p class="text-xs">No API key is configured. Anyone with network access can use the MCP server. Set the <code>McpApiKey</code> environment variable to restrict access.</p>
            </div>
        </div>
    }

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <!-- Database Service -->
        <div class="card bg-base-100 shadow-sm">
            <div class="card-body">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div class="bg-base-200 rounded-lg p-2">
                            <icon name="circle-stack" size="5" class="text-base-content/70" />
                        </div>
                        <div>
                            <h2 class="font-semibold">Database</h2>
                            <p class="text-sm text-base-content/50">PostgreSQL + ParadeDB</p>
                        </div>
                    </div>
                    @if (Model.DatabaseConnected) {
                        <span class="badge badge-success" data-status-db>Connected</span>
                    } else {
                        <span class="badge badge-error" data-status-db>Disconnected</span>
                    }
                </div>
            </div>
        </div>

        <!-- Workers Overview Service -->
        <div class="card bg-base-100 shadow-sm">
            <div class="card-body">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div class="bg-base-200 rounded-lg p-2">
                            <icon name="cog-6-tooth" size="5" class="text-base-content/70" />
                        </div>
                        <div>
                            <h2 class="font-semibold">Workers</h2>
                            <p class="text-sm text-base-content/50">Background scrapers &amp; processors</p>
                        </div>
                    </div>
                    @if (activeWorkers == totalWorkers) {
                        <span class="badge badge-success" data-status-workers>@activeWorkers/@totalWorkers active</span>
                    } else {
                        <span class="badge badge-warning" data-status-workers>@activeWorkers/@totalWorkers active</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Data Statistics -->
    <div class="card bg-base-100 shadow-sm @(!Model.DatabaseConnected ? "hidden" : "")" data-status-data-card>
        <div class="card-body">
            <h2 class="card-title text-lg mb-2">Data</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-4">
                <div class="text-center">
                    <div class="text-2xl font-bold" data-status-count="StockCount">@Model.StockCount.ToString("N0")</div>
                    <div class="text-xs text-base-content/50">Stocks</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold" data-status-count="DocumentCount">@Model.DocumentCount.ToString("N0")</div>
                    <div class="text-xs text-base-content/50">SEC Filings</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold" data-status-count="InsiderTransactionCount">@Model.InsiderTransactionCount.ToString("N0")</div>
                    <div class="text-xs text-base-content/50">Insider Transactions</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold" data-status-count="CongressionalTradeCount">@Model.CongressionalTradeCount.ToString("N0")</div>
                    <div class="text-xs text-base-content/50">Congressional Trades</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold" data-status-count="InstitutionalHoldingCount">@Model.InstitutionalHoldingCount.ToString("N0")</div>
                    <div class="text-xs text-base-content/50">Institutional Holdings</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold" data-status-count="FailToDeliverCount">@Model.FailToDeliverCount.ToString("N0")</div>
                    <div class="text-xs text-base-content/50">Fails to Deliver</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold" data-status-count="FredObservationCount">@Model.FredObservationCount.ToString("N0")</div>
                    <div class="text-xs text-base-content/50">Economic Indicators</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold" data-status-count="DailyStockPriceCount">@Model.DailyStockPriceCount.ToString("N0")</div>
                    <div class="text-xs text-base-content/50">Daily Prices</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Workers Detail -->
    <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
            <h2 class="card-title text-lg mb-2">Workers</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3" data-status-worker-grid>
                @foreach (var worker in Model.Workers) {
                    <div class="flex items-start gap-3 p-3 rounded-lg bg-base-200/50" data-status-worker="@worker.Name">
                        <div class="mt-0.5">
                            @if (worker.Active) {
                                <span class="inline-block w-2 h-2 rounded-full bg-success" data-status-worker-dot></span>
                            } else {
                                <span class="inline-block w-2 h-2 rounded-full bg-warning" data-status-worker-dot></span>
                            }
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2">
                                <span class="font-medium text-sm">@worker.Name</span>
                                @if (!worker.Active) {
                                    <span class="badge badge-warning badge-xs" data-status-worker-badge>Inactive</span>
                                } else {
                                    <span class="badge badge-warning badge-xs hidden" data-status-worker-badge>Inactive</span>
                                }
                            </div>
                            <p class="text-xs text-base-content/50 mt-0.5" data-status-worker-reason>@worker.Reason</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Errors -->
    <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3">
                    <h2 class="card-title text-lg">Errors</h2>
                    @if (Model.UnseenErrorCount > 0) {
                        <span class="badge badge-warning" data-status-unseen-errors>@Model.UnseenErrorCount new</span>
                    } else {
                        <span class="badge badge-warning hidden" data-status-unseen-errors>0 new</span>
                    }
                    <span class="text-sm text-base-content/50" data-status-total-errors>@Model.TotalErrorCount total</span>
                </div>
                @if (Model.TotalErrorCount > 0) {
                    <form asp-action="DeleteAll" class="form-confirm" data-message="Delete ALL errors? This cannot be undone.">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-error btn-sm">
                            <icon name="trash" size="4" /> Delete All
                        </button>
                    </form>
                }
            </div>

            <!-- Source filter buttons -->
            <div class="flex flex-wrap items-center gap-2 mb-4">
                <a asp-action="Index" asp-route-search="@search"
                   class="btn btn-xs @(string.IsNullOrEmpty(sourceFilter) ? "btn-primary" : "btn-ghost")">All</a>
                @foreach (var source in ErrorSource.GetAll()) {
                    <a asp-action="Index" asp-route-source="@source.Value" asp-route-search="@search"
                       class="btn btn-xs @(sourceFilter == source.Value ? "btn-primary" : "btn-ghost")">@source.Value</a>
                }
            </div>

            <!-- Search -->
            <form asp-action="Index" class="mb-4">
                <input type="hidden" name="source" value="@sourceFilter" />
                <input type="text" name="search" value="@search" placeholder="Search errors..."
                       class="input input-bordered input-sm w-full max-w-md" />
            </form>

            @if (Model.RecentErrors.Count == 0) {
                <div class="text-center py-8 text-base-content/50">
                    <icon name="check-circle" size="10" class="mx-auto mb-2 opacity-50" />
                    <p class="text-sm">No errors found</p>
                </div>
            } else {
                <div class="overflow-x-auto">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Source</th>
                                <th>Context</th>
                                <th>Message</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th class="w-1"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var error in Model.RecentErrors) {
                                <tr>
                                    <td><span class="badge badge-primary badge-xs">@error.Source</span></td>
                                    <td class="text-sm">@error.Context</td>
                                    <td class="text-sm">@(error.Message != null && error.Message.Length > 80 ? error.Message[..80] + "..." : error.Message)</td>
                                    <td>
                                        @if (error.Seen) {
                                            <span class="badge badge-ghost badge-xs">Seen</span>
                                        } else {
                                            <span class="badge badge-warning badge-xs">New</span>
                                        }
                                    </td>
                                    <td class="whitespace-nowrap text-sm text-base-content/50">@error.CreationTime.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <div class="flex items-center gap-1">
                                            <a asp-action="Show" asp-route-id="@error.Id" class="btn btn-ghost btn-xs">
                                                <icon name="eye" size="4" />
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@error.Id" class="form-confirm" data-message="Delete this error?">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-ghost btn-xs text-error">
                                                    <icon name="trash" size="4" />
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Live refresh — polls /Status/Data at a configurable interval and updates dynamic elements in-place
        (function () {
            const DATA_URL = '@Url.Action("Data", "Status")';
            const spinner = document.querySelector('[data-status-spinner]');
            const countdown = document.querySelector('[data-status-countdown]');
            const toggle = document.querySelector('[data-status-toggle]');
            const intervalButtons = document.querySelectorAll('[data-status-interval]');

            let interval = 5;
            let remaining = interval;
            let refreshing = false;
            let enabled = true;
            let timer = null;

            // Format a number with locale-aware thousand separators
            function formatNumber(n) {
                return n.toLocaleString();
            }

            // Update the database connection badge and data card visibility
            function updateDatabase(connected) {
                const badge = document.querySelector('[data-status-db]');
                if (!badge) return;
                badge.textContent = connected ? 'Connected' : 'Disconnected';
                badge.className = connected ? 'badge badge-success' : 'badge badge-error';

                const dataCard = document.querySelector('[data-status-data-card]');
                if (dataCard) dataCard.classList.toggle('hidden', !connected);
            }

            // Update the workers overview badge
            function updateWorkersBadge(active, total) {
                const badge = document.querySelector('[data-status-workers]');
                if (!badge) return;
                badge.textContent = active + '/' + total + ' active';
                badge.className = active === total ? 'badge badge-success' : 'badge badge-warning';
            }

            // Update individual data count elements
            function updateDataCounts(counts) {
                for (const key in counts) {
                    const el = document.querySelector('[data-status-count="' + key + '"]');
                    if (el) el.textContent = formatNumber(counts[key]);
                }
            }

            // Update worker detail cards (dot color, badge visibility, reason text)
            function updateWorkers(workers) {
                for (const w of workers) {
                    const card = document.querySelector('[data-status-worker="' + w.name + '"]');
                    if (!card) continue;

                    const dot = card.querySelector('[data-status-worker-dot]');
                    if (dot) dot.className = 'inline-block w-2 h-2 rounded-full ' + (w.active ? 'bg-success' : 'bg-warning');

                    const badge = card.querySelector('[data-status-worker-badge]');
                    if (badge) badge.classList.toggle('hidden', w.active);

                    const reason = card.querySelector('[data-status-worker-reason]');
                    if (reason) reason.textContent = w.reason;
                }
            }

            // Update error count badges
            function updateErrors(totalCount, unseenCount) {
                const unseenBadge = document.querySelector('[data-status-unseen-errors]');
                if (unseenBadge) {
                    unseenBadge.textContent = unseenCount + ' new';
                    unseenBadge.classList.toggle('hidden', unseenCount === 0);
                }

                const totalEl = document.querySelector('[data-status-total-errors]');
                if (totalEl) totalEl.textContent = totalCount + ' total';
            }

            // Fetch fresh status data and update the page
            function refresh() {
                if (refreshing) return;
                refreshing = true;
                spinner.classList.remove('hidden');
                fetch(DATA_URL)
                    .then(function (r) {
                        if (!r.ok) throw new Error('HTTP ' + r.status);
                        return r.json();
                    })
                    .then(function (data) {
                        updateDatabase(data.databaseConnected);
                        updateWorkersBadge(data.activeWorkerCount, data.totalWorkerCount);
                        updateDataCounts(data.dataCounts);
                        updateWorkers(data.workers);
                        updateErrors(data.totalErrorCount, data.unseenErrorCount);
                    })
                    .catch(function () {
                        // Will retry on next tick
                    })
                    .finally(function () {
                        spinner.classList.add('hidden');
                        refreshing = false;
                        remaining = interval;
                    });
            }

            // Start the 1-second ticker
            function startTimer() {
                if (timer) return;
                timer = setInterval(tick, 1000);
            }

            // Stop the ticker
            function stopTimer() {
                clearInterval(timer);
                timer = null;
            }

            // Countdown ticker — runs every second, triggers refresh at zero
            function tick() {
                remaining--;
                if (remaining <= 0) {
                    countdown.textContent = 'Refreshing…';
                    refresh();
                } else {
                    countdown.textContent = remaining + 's';
                }
            }

            // Update countdown display based on enabled state
            function updateCountdownDisplay() {
                if (enabled) {
                    countdown.textContent = remaining + 's';
                } else {
                    countdown.textContent = 'Paused';
                }
            }

            // Toggle auto-refresh on/off
            toggle.addEventListener('change', function () {
                enabled = toggle.checked;
                if (enabled) {
                    remaining = 1;
                    startTimer();
                } else {
                    stopTimer();
                }
                updateCountdownDisplay();
            });

            // Interval selection buttons
            intervalButtons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    // Update active button style
                    intervalButtons.forEach(function (b) { b.classList.remove('btn-active'); });
                    btn.classList.add('btn-active');

                    // Set new interval and reset countdown
                    interval = parseInt(btn.dataset.statusInterval, 10);
                    remaining = 1;
                    updateCountdownDisplay();

                    // Auto-enable if currently paused
                    if (!enabled) {
                        enabled = true;
                        toggle.checked = true;
                        startTimer();
                    }
                });
            });

            // Initialize
            countdown.textContent = interval + 's';
            startTimer();

            // Pause when the tab is hidden, resume when visible
            document.addEventListener('visibilitychange', function () {
                if (!enabled) return;
                if (document.hidden) {
                    stopTimer();
                } else {
                    remaining = 1;
                    startTimer();
                }
            });
        })();
    </script>
}
