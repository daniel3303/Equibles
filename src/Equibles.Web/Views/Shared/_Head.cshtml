@{
    var title = ViewData["Title"]?.ToString() ?? "US Stock Market Financial Data";
    var fullTitle = $"{title} - Equibles";
    var description = ViewData["Description"]?.ToString()
        ?? "Equibles - US Stock Market Financial Data. Institutional holdings, short volume, short interest, and fails-to-deliver data.";
    var canonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
}

<title lang="en">@fullTitle</title>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content="@description" />
<link rel="canonical" href="@canonicalUrl" />

<!-- Favicon -->
<link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon/favicon-16x16.png">
<link rel="apple-touch-icon" sizes="180x180" href="/favicon/favicon/apple-touch-icon.png">
<link rel="manifest" href="/favicon/favicon/site.webmanifest">
<link rel="mask-icon" href="/favicon/favicon/safari-pinned-tab.svg" color="#1a1a2e">

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content="@fullTitle" />
<meta property="og:description" content="@description" />
<meta property="og:url" content="@canonicalUrl" />
<meta property="og:site_name" content="Equibles" />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content="@baseUrl/favicon/favicon/android-chrome-512x512.png" />
<meta property="og:image:width" content="512" />
<meta property="og:image:height" content="512" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content="@fullTitle" />
<meta name="twitter:description" content="@description" />
<meta name="twitter:image" content="@baseUrl/favicon/favicon/android-chrome-512x512.png" />

<!-- Google Fonts - Inter -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" type="text/css" href="~/dist/main.css" asp-append-version="true" />

<meta name="apple-mobile-web-app-title" content="Equibles">
<meta name="application-name" content="Equibles">
<meta name="theme-color" content="#ffffff">
